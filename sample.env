# =============================================================================
# RHOAI Custom Deep Research Lab — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp sample.env .env
#
# Two access modes are supported:
#
#   Mode A — Direct vLLM route (no MaaS)
#     LLM_BASE_URL  = https://<model-route>/v1
#     LLM_API_KEY   = <oc-token or "not-needed">
#     MAAS_API_KEY  = (leave empty)
#
#   Mode B — MaaS API gateway
#     LLM_BASE_URL  = https://<maas-api-route>/<namespace>/<model>/v1
#     LLM_API_KEY   = (ignored when MAAS_API_KEY is set)
#     MAAS_API_KEY  = sk-oai-... (MaaS API key bound to subscription)
#
# =============================================================================

# --- LLM Configuration (RHOAI Model Serving / OpenAI-compatible) ---
# Direct route example : https://granite-llm-doc-research.apps.cluster.example.com/v1
# MaaS gateway example : https://maas-api.apps.cluster.example.com/demo/granite-llm/v1
LLM_BASE_URL=https://<your-llm-route>/v1
LLM_API_KEY=<your-api-key>
LLM_MODEL=granite-3.3-8b-instruct

# MaaS API key (required for MaaS gateway, leave empty for direct routes)
# POST /chat/completions requires this key; OC tokens only work for GET /models
MAAS_API_KEY=

# --- Embedding Model ---
# Required: Set your embedding endpoint URL before starting the lab.
# Example: https://granite-embedding-doc-research.apps.cluster.example.com/v1
EMBEDDING_BASE_URL=https://<your-embedding-route>/v1
EMBEDDING_API_KEY=<your-api-key>
EMBEDDING_MODEL=granite-embedding-278m-multilingual

# --- PostgreSQL + pgvector ---
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DB=doc_research
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=postgres
PGVECTOR_COLLECTION=documents

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

# --- Kagenti Platform ---
KAGENTI_PLATFORM_URL=http://localhost:8080
KAGENTI_NAMESPACE=doc-research

# --- SSL Verification ---
# Set to false for self-signed certificates on sandbox/lab clusters
VERIFY_SSL=true

# --- LLM Token Limits ---
# Thinking models (e.g. Qwen3) generate long internal reasoning;
# always set max_tokens to prevent MaaS gateway timeouts.
LLM_MAX_TOKEN_SMALL=512
LLM_MAX_TOKEN_MEDIUM=1024
LLM_MAX_TOKEN_LARGE=4096

# --- Harness Configuration ---
QUALITY_THRESHOLD=7.0
MAX_ITERATIONS=3

# --- MCP Server URLs (local development) ---
DOC_MCP_URL=http://localhost:9001
SEARCH_MCP_URL=http://localhost:9002
ANALYSIS_MCP_URL=http://localhost:9003

# --- Agent Ports (local development) ---
ORCHESTRATOR_PORT=8100
DOC_PROCESSOR_PORT=8101
RESEARCHER_PORT=8102
WRITER_PORT=8103

# --- UI Ports (local development) ---
BACKEND_PORT=8000
FRONTEND_PORT=7860
API_URL=http://localhost:8000

# --- OpenShift (populated by setup notebooks) ---
CLUSTER_DOMAIN=
NAMESPACE=doc-research-lab
